<img src=\"images/downscaling/3_terciles_ecmwf_lead032026_AMJ.png\" class=\"result-img\" alt=\"ECMWF\"/><p class=\"img-caption\">ECMWF-SEAS5.1</p></div>\n            <div><img src=\"images/downscaling/3_terciles_dwd_lead032026_AMJ.png\" class=\"result-img\" alt=\"DWD\"/><p class=\"img-caption\">DWD</p></div>\n            <div><img src=\"images/downscaling/3_terciles_cmcc_lead032026_AMJ.png\" class=\"result-img\" alt=\"CMCC\"/><p class=\"img-caption\">CMCC</p></div>\n            <div><img src=\"images/downscaling/3_terciles_meteo_france_lead032026_AMJ.png\" class=\"result-img\" alt=\"Météo-France\"/><p class=\"img-caption\">Météo-France</p></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Correlación Spearman -->\n    <div class=\"accordion-item\">\n      <h2 class=\"accordion-header\">\n        <button class=\"accordion-button collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#graf-corr\">\n          Correlación de Spearman\n        </button>\n      </h2>\n      <div id=\"graf-corr\" class=\"accordion-collapse collapse\" data-bs-parent=\"#accordion-graficos\">\n        <div class=\"accordion-body\">\n          <div class=\"grid-2\">\n            <div><img src=\"images/downscaling/4_corr-spearman_ecmwf_lead032026_AMJ.png\" class=\"result-img\" alt=\"ECMWF\"/><p class=\"img-caption\">ECMWF-SEAS5.1</p></div>\n            <div><img src=\"images/downscaling/4_corr-spearman_dwd_lead032026_AMJ.png\" class=\"result-img\" alt=\"DWD\"/><p class=\"img-caption\">DWD</p></div>\n            <div><img src=\"images/downscaling/4_corr-spearman_cmcc_lead032026_AMJ.png\" class=\"result-img\" alt=\"CMCC\"/><p class=\"img-caption\">CMCC</p></div>\n            <div><img src=\"images/downscaling/4_corr-spearman_meteo_france_lead032026_AMJ.png\" class=\"result-img\" alt=\"Météo-France\"/><p class=\"img-caption\">Météo-France</p></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ROC -->\n    <div class=\"accordion-item\">\n      <h2 class=\"accordion-header\">\n        <button class=\"accordion-button collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#graf-roc\">\n          Curvas ROC\n        </button>\n      </h2>\n      <div id=\"graf-roc\" class=\"accordion-collapse collapse\" data-bs-parent=\"#accordion-graficos\">\n        <div class=\"accordion-body\">\n          <div class=\"grid-2\">\n            <div><img src=\"images/downscaling/5_roc_3_pr_ecmwf_lead032026_AMJ.png\" class=\"result-img\" alt=\"ECMWF\"/><p class=\"img-caption\">ECMWF-SEAS5.1</p></div>\n            <div><img src=\"images/downscaling/5_roc_3_pr_dwd_lead032026_AMJ.png\" class=\"result-img\" alt=\"DWD\"/><p class=\"img-caption\">DWD</p></div>\n            <div><img src=\"images/downscaling/5_roc_3_pr_cmcc_lead032026_AMJ.png\" class=\"result-img\" alt=\"CMCC\"/><p class=\"img-caption\">CMCC</p></div>\n            <div><img src=\"images/downscaling/5_roc_3_pr_meteo_france_lead032026_AMJ.png\" class=\"result-img\" alt=\"Météo-France\"/><p class=\"img-caption\">Météo-France</p></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- RPS -->\n    <div class=\"accordion-item\">\n      <h2 class=\"accordion-header\">\n        <button class=\"accordion-button collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#graf-rps\">\n          Ranked Probability Score (RPS)\n        </button>\n      </h2>\n      <div id=\"graf-rps\" class=\"accordion-collapse collapse\" data-bs-parent=\"#accordion-graficos\">\n        <div class=\"accordion-body\">\n          <div class=\"grid-2\">\n            <div><img src=\"images/downscaling/6_rps_pr_ecmwf_lead032026_AMJ.png\" class=\"result-img\" alt=\"ECMWF\"/><p class=\"img-caption\">ECMWF-SEAS5.1</p></div>\n            <div><img src=\"images/downscaling/6_rps_pr_dwd_lead032026_AMJ.png\" class=\"result-img\" alt=\"DWD\"/><p class=\"img-caption\">DWD</p></div>\n            <div><img src=\"images/downscaling/6_rps_p